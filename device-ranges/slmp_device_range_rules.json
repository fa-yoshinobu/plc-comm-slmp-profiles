  "runtime_probes": {
    "reason": "Q系の一部デバイスはPLC側でSDにデバイス範囲が書き込まれない問題があるため、SD読出しだけでは確定できず、読出し可否の散策（プローブ）で境界を求める",
    "applies_to": [
      "melsec:lcpu",
      "melsec:qcpu",
      "melsec:qnu",
      "melsec:qnudv"
    ],
    "max_probe_count": 1048576,
    "probe_read": "対象アドレスをワード1点読出しし、SLMPエラーなら読出し不可とみなす",
    "steps": [
      {
        "order": 1,
        "profiles": [
          "melsec:qcpu"
        ],
        "family": "Z",
        "method": "single-address-check",
        "spec": "Z15 が読めれば点数16、読めなければ点数10"
      },
      {
        "order": 2,
        "profiles": [
          "melsec:lcpu",
          "melsec:qcpu",
          "melsec:qnu",
          "melsec:qnudv"
        ],
        "family": "ZR",
        "method": "doubling-then-binary-search",
        "spec": "ZR0 が読めなければ点数0。読めたら high を 1 から (high*2)+1 で倍化し読めなくなるまで進め（上限 max_probe_count-1）、最後に low..high を二分探索して最大読出し可能アドレス+1 を点数とする。上限アドレスまで読めたら max_probe_count"
      },
      {
        "order": 3,
        "profiles": [
          "melsec:lcpu",
          "melsec:qcpu",
          "melsec:qnu",
          "melsec:qnudv"
        ],
        "family": "R",
        "method": "derived",
        "spec": "min(ZRの散策点数, 32768) を R の点数とする"
      }
    ],
    "source_note": "散策結果は source='Runtime access check' としてカタログに記録する"
  },
