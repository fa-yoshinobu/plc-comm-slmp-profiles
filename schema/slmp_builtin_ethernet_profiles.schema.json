{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fa-yoshinobu/plc-comm-slmp-profiles/schema/slmp_builtin_ethernet_profiles.schema.json",
  "title": "MELSEC SLMP built-in Ethernet capability profiles",
  "type": "object",
  "required": [
    "schema_version",
    "date",
    "scope",
    "description",
    "policy",
    "evidence_files",
    "profiles"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "date": {
      "type": "string"
    },
    "scope": {
      "const": "builtin-ethernet-port"
    },
    "description": {
      "type": "string"
    },
    "policy": {
      "type": "object"
    },
    "evidence_files": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/profile"
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "required": [
        "display_name",
        "frame",
        "compat",
        "subcommands",
        "verified_models",
        "features",
        "limits",
        "write_policy"
      ],
      "additionalProperties": false,
      "properties": {
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "frame": {
          "enum": [
            "3E",
            "4E"
          ]
        },
        "compat": {
          "type": "string"
        },
        "subcommands": {
          "type": "object",
          "required": [
            "word",
            "bit",
            "ext_word",
            "ext_bit"
          ],
          "additionalProperties": {
            "type": "string"
          }
        },
        "verified_models": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "features": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/feature"
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/limit"
          }
        },
        "write_policy": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "feature": {
      "type": "object",
      "required": [
        "state",
        "source"
      ],
      "additionalProperties": false,
      "properties": {
        "state": {
          "enum": [
            "supported",
            "blocked",
            "config-dependent",
            "unverified",
            "delegated"
          ]
        },
        "source": {
          "type": "string"
        }
      }
    },
    "limit": {
      "type": "object",
      "required": [
        "source"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string"
        },
        "max": {
          "type": "integer",
          "minimum": 0
        },
        "weighted_max": {
          "type": "integer",
          "minimum": 0
        },
        "over_end_code": {
          "type": "string"
        }
      }
    }
  }
}

